    icon: "📱",
    title: "Marketing Digital",
    description: "Estrategias en redes sociales, SEO, SEM y contenido digital para aumentar tu presencia online"
  },
  {
    icon: "🎬",
    title: "Producción Audiovisual",
    description: "Creación de videos comerciales, spots publicitarios y contenido multimedia de alto impacto"
  },
  {
    icon: "🎨",
    title: "Diseño Creativo",
    description: "Branding, diseño gráfico y desarrollo de identidad visual que refleje la esencia de tu marca"
  },
  {
    icon: "📊",
    title: "Estrategia de Marca",
    description: "Planificación estratégica y posicionamiento de marca para destacar en tu mercado"
  },
  {
    icon: "📸",
    title: "Fotografía Comercial",
