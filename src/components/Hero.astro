---
---

<section class="hero">
  <div class="hero-content">
    <h1>Transforma tu negocio con tecnología</h1>
    <p>La solución definitiva para impulsar tu productividad y alcanzar tus objetivos</p>
    <div class="hero-buttons">
      <button class="primary">Prueba gratis</button>
      <button class="secondary">Ver demo</button>
    </div>
  </div>
  <div class="hero-image">
    <div class="placeholder-image">
      🚀
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8rem 5% 4rem;
    max-width: 1400px;
    margin: 0 auto;
    gap: 4rem;
    min-height: 90vh;
  }
  
  .hero-content {
    flex: 1;
  }
  
  .hero-content h1 {
    font-size: 3.5rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
  }
  
  .hero-content p {
    font-size: 1.25rem;
    color: #666;
    margin-bottom: 2rem;
  }
  
  .hero-buttons {
    display: flex;
    gap: 1rem;
  }
  
  button {
    padding: 1rem 2rem;
    font-size: 1rem;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s;
  }
  
  .primary {
    background: #0070f3;
    color: white;
    border: none;
  }
  
  .primary:hover {
    background: #0051cc;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0,112,243,0.3);
  }
  
  .secondary {
    background: white;
    color: #0070f3;
    border: 2px solid #0070f3;
  }
  
  .secondary:hover {
    background: #f0f8ff;
  }
  
  .hero-image {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .placeholder-image {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  
  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      text-align: center;
      padding-top: 6rem;
    }
    
    .hero-content h1 {
      font-size: 2rem;
    }
    
    .hero-buttons {
      justify-content: center;
    }
    
    .placeholder-image {
      width: 300px;
      height: 300px;
      font-size: 6rem;
    }
  }
</style>
